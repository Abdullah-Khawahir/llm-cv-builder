FROM mcr.microsoft.com/dotnet/sdk:10.0

WORKDIR /app

# WeasyPrint dependencies
RUN apt-get update && apt-get install -y \
    libcairo2 \
    libpango-1.0-0 \
    libpangocairo-1.0-0 \
    libgdk-pixbuf-2.0-0 \
    libffi-dev \
    fontconfig \
    fonts-dejavu \
    shared-mime-info \
    weasyprint \
    && rm -rf /var/lib/apt/lists/*

COPY WebAPI.csproj ./
RUN dotnet restore

COPY . .

EXPOSE 8080

